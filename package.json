{
	"name": "@ktarmyshov/svelte-adapter-azure-swa",
	"description": "SvelteKit adapter for Azure Static Web Apps.",
	"version": "0.24.0",
	"workspaces": [
		".",
		"tests/demo",
		"tests/new-demo"
	],
	"scripts": {
		"prepare": "npm run prepare --workspace tests/demo",
		"build": "npm run gen:swa-conig-ts",
		"build:release": "npm run build",
		"format": "prettier --write .",
		"format:all": "npm run format --workspaces",
		"check": "tsc --skipLibCheck --noEmit",
		"check:all": "npm run check --workspaces",
		"lint": "prettier --check . && eslint .",
		"lint:all": "npm run lint --workspaces",
		"test": "vitest --run",
		"coverage": "vitest --coverage --run",
		"changeset:version": "changeset version && npm install && git add --all",
		"changeset:publish": "changeset publish",
		"gen:swa-conig-ts": "curl https://www.schemastore.org/staticwebapp.config.json | npx json-schema-to-typescript > ./src/types/swa-config-gen.d.ts && prettier --write ./src/types/swa-config-gen.d.ts",
		"clean:nm": "find . -type d -name node_modules -not -path '*/node_modules/*/node_modules' -prune -exec rm -rf '{}' +",
		"clean:nm:lock": "npm run clean:nm && find . -name 'package-lock.json' -type f -exec rm -rf '{}' +"
	},
	"main": "./src/index.js",
	"types": "./src/index.d.ts",
	"module": "./src/index.js",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"import": "./src/index.js"
		},
		"./package.json": "./package.json"
	},
	"license": "MIT",
	"keywords": [
		"svelte",
		"sveltekit",
		"sveltekit-adapter",
		"azure",
		"staticwebapp"
	],
	"homepage": "https://github.com/kt-npm-modules/svelte-adapter-azure-swa#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kt-npm-modules/svelte-adapter-azure-swa.git"
	},
	"bugs": {
		"url": "https://github.com/kt-npm-modules/svelte-adapter-azure-swa/issues"
	},
	"peerDependencies": {
		"@azure/functions": "^4.0.0",
		"@sveltejs/kit": "^2.54.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^10.0.0",
		"@sveltejs/kit": "^2.55.0",
		"@types/node": "^25.0.2",
		"@types/set-cookie-parser": "^2.4.7",
		"@vitest/coverage-istanbul": "^4.0.15",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.2",
		"globals": "^17.0.0",
		"json-schema-to-typescript": "^15.0.4",
		"monocart-coverage-reports": "^2.12.9",
		"prettier": "^3.5.3",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.31.0",
		"vitest": "^4.0.15"
	},
	"dependencies": {
		"@rollup/plugin-alias": "^6.0.0",
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.1",
		"@vitest/browser": "^4.0.15",
		"lodash": "^4.17.23",
		"rollup": "^4.59.0",
		"rollup-plugin-sourcemaps2": "0.5.6",
		"set-cookie-parser": "^3.0.1",
		"vitest-browser-svelte": "^2.0.1"
	},
	"files": [
		"src"
	],
	"engines": {
		"node": ">=20 <21 || >=22 <23"
	}
}
