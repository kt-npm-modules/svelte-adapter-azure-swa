{
	"name": "demo",
	"private": true,
	"version": "0.0.3",
	"type": "module",
	"scripts": {
		"dev": "PUBLIC_SWA=${PUBLIC_SWA:-false} vite dev",
		"swa": "PUBLIC_SWA=true swa start",
		"build": "PUBLIC_SWA=${PUBLIC_SWA:-false} vite build",
		"build:swa": "PUBLIC_SWA=true npm run build",
		"preview": "PUBLIC_SWA=${PUBLIC_SWA:-false} vite preview",
		"prepare": "PUBLIC_SWA=${PUBLIC_SWA:-false} svelte-kit sync || echo ''",
		"check": "PUBLIC_SWA=${PUBLIC_SWA:-false} svelte-kit sync && PUBLIC_SWA=${PUBLIC_SWA:-false} svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:swa": "PUBLIC_SWA=true npm run test"
	},
	"devDependencies": {
		"@azure/functions": "^4.12.0",
		"@azure/static-web-apps-cli": "^2.0.8",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^9.22.0",
		"@fontsource/fira-mono": "^5.2.7",
		"@inlang/paraglide-js": "^2.15.1",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@vitest/browser": "^4",
		"@vitest/browser-playwright": "^4.0.15",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"playwright": "^1.56.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.0",
		"svelte-adapter-azure-swa": "file:../..",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.1.11",
		"vitest": "^4",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@azure/cosmos": "^4.9.2",
		"@sentry/sveltekit": "^10.45.0"
	},
	"engines": {
		"node": ">=22 <23"
	}
}
