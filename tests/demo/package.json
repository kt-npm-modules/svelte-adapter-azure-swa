{
	"name": "demo",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "PUBLIC_SWA_CLI=${PUBLIC_SWA_CLI:-false} vite dev",
		"swa": "PUBLIC_SWA_CLI=true swa start",
		"build": "PUBLIC_SWA_CLI=${PUBLIC_SWA_CLI:-false} vite build",
		"build:swa": "PUBLIC_SWA_CLI=true npm run build",
		"preview": "PUBLIC_SWA_CLI=${PUBLIC_SWA_CLI:-false} vite preview",
		"prepare": "PUBLIC_SWA_CLI=${PUBLIC_SWA_CLI:-false} svelte-kit sync || echo ''",
		"check": "PUBLIC_SWA_CLI=${PUBLIC_SWA_CLI:-false} svelte-kit sync && PUBLIC_SWA_CLI=${PUBLIC_SWA_CLI:-false} svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:swa": "npm run build:swa && PUBLIC_SWA_CLI=true npm run test"
	},
	"devDependencies": {
		"@azure/functions": "^4.12.0",
		"@azure/static-web-apps-cli": "^2.0.8",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-mono": "^5.2.7",
		"@inlang/paraglide-js": "^2.16.0",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.59.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.1.2",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"monocart-coverage-reports": "^2.12.9",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.4",
		"svelte-adapter-azure-swa": "file:../..",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0"
	},
	"engines": {
		"node": ">=20 <21 || >=22 <23"
	},
	"dependencies": {
		"@sentry/sveltekit": "^10.48.0"
	}
}
