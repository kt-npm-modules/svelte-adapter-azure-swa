		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"engines": {
		"node": ">=20 <21 || >=22 <23"
